rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Relatórios IAF — somente leitura
    match /iafReports/{docId} {
      allow read: if true;
    }

    // Último IAF publicado — somente leitura
    match /iafLatest/{docId} {
      allow read: if true;
    }

    // Usuários
    match /users/{userId} {
      allow read: if true;

      // Permite update apenas no campo selectedPillars
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(["selectedPillars"]);

      // Tokens de push por usuário
      match /notificationTokens/{tokenId} {
        allow read, write: if true;
      }
    }

    // Tokens globais de push — usado pelo n8n
    match /pushTokens/{tokenId} {
      allow read, write: if true;
    }

    // Logs de acesso
    match /accessLogs/{logId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(["userId", "timestamp"])
                    && request.resource.data.keys().hasOnly([
                         "userId", "timestamp", "userAgent", "platform", "isStandalone"
                       ]);
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(["timestamp", "userAgent", "platform", "isStandalone"]);
    }

  }
}
