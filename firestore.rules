rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Relatórios IAF — somente leitura
    match /iafReports/{docId} {
      allow read: if true;
    }

    // Último IAF publicado — somente leitura
    match /iafLatest/{docId} {
      allow read: if true;
    }

    // Usuários
    match /users/{userId} {
      allow read: if true;

      // Permite update apenas no campo selectedPillars
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(["selectedPillars"]);

      // Tokens FCM por usuário (legado)
      match /notificationTokens/{tokenId} {
        allow read, write: if true;
      }

      // Subscriptions OneSignal por usuário
      match /oneSignalSubscriptions/{subscriptionId} {
        allow read, write: if true;
      }
    }

    // Tokens FCM globais (legado)
    match /pushTokens/{tokenId} {
      allow read, write: if true;
    }

    // Subscriptions OneSignal globais — usado pelo n8n
    match /oneSignalSubscriptions/{subscriptionId} {
      allow read, write: if true;
    }

    // Logs de acesso diário
    match /accessLogs/{logId} {
      allow read, write: if true;
    }

  }
}
