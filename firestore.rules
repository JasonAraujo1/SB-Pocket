rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if true;

      match /notificationTokens/{tokenId} {
        allow read, write: if true;
      }
    }

    match /pushTokens/{tokenId} {
      allow read, write: if true;
    }

  }
}
